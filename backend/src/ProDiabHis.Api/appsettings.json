{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/prodiabhis-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Issuer": "ProDiabHis",
    "Audience": "ProDiabHis"
  },
  "AllowedHosts": "*",
  "CorsHardening": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://app.prodiab.vn"
    ]
  },
  "Minio": {
    "BucketName": "prodiab"
  },
  "Dtqg": {
    "Enabled": false,
    "BaseUrl": "https://api.donthuocquocgia.vn",
    "ApiToken": "",
    "SubmitPath": "/api/v1/don-thuoc",
    "StatusPath": "/api/v1/don-thuoc/{ma}/trang-thai",
    "CancelPath": "/api/v1/don-thuoc/{ma}/huy",
    "PingPath": "/api/v1/ping",
    "TimeoutSeconds": 30
  }
}
