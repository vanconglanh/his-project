[mysqld]
# =====================================================
# Pro-Diab HIS — MySQL 8.0 config
# =====================================================

# --- Character set & Collation ---
character-set-server        = utf8mb4
collation-server            = utf8mb4_0900_ai_ci
character_set_client_results = utf8mb4

# --- InnoDB ---
default_storage_engine      = InnoDB
innodb_file_per_table       = ON
innodb_buffer_pool_size     = 256M
innodb_log_file_size        = 64M
innodb_flush_log_at_trx_commit = 1
innodb_flush_method         = O_DIRECT

# --- Connections ---
max_connections             = 200
wait_timeout                = 600
interactive_timeout         = 600
connect_timeout             = 10

# --- Query cache (MySQL 8 da bo, giu comment de ghi nho) ---
# query_cache_type = 0  -- da bi xoa khoi MySQL 8

# --- Binary log (can thiet cho backup incremental & replication) ---
log_bin                     = mysql-bin
binlog_format               = ROW
expire_logs_days            = 7
sync_binlog                 = 1

# --- Slow query log ---
slow_query_log              = ON
slow_query_log_file         = /var/log/mysql/slow.log
long_query_time             = 2
log_queries_not_using_indexes = ON

# --- General ---
max_allowed_packet          = 64M
tmp_table_size              = 64M
max_heap_table_size         = 64M
open_files_limit            = 65535

# --- Timezone ---
default_time_zone           = '+07:00'

# --- SQL mode (strict nhung khong can NO_AUTO_CREATE_USER vi MySQL 8 da bo) ---
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[mysql]
default-character-set = utf8mb4

[client]
default-character-set = utf8mb4
