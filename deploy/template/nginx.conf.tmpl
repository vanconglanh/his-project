# Nginx noi bo stack phong kham {{CLINIC_NAME}} ({{CLINIC_CODE}}) — SINH TU DONG.
# Gop frontend + backend sau 1 cong (container :80 -> host 172.17.0.1:{{NGINX_PORT}}).
# Nginx host ngoai proxy {{DOMAIN}} -> 172.17.0.1:{{NGINX_PORT}} (SSL o nginx host ngoai).
upstream prodiab_frontend { server frontend:3000; }
upstream prodiab_backend  { server backend:5000; }

server {
    listen 80;
    server_name {{DOMAIN}};

    client_max_body_size 25m;

    location /api/ {
        proxy_pass http://prodiab_backend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_read_timeout 120s;
    }

    location /healthz { proxy_pass http://prodiab_backend; }

    location / {
        proxy_pass http://prodiab_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_read_timeout 120s;
    }
}
