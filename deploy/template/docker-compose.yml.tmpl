# =====================================================================
# Pro-Diab HIS — Docker Compose cho phong kham: {{CLINIC_NAME}} ({{CLINIC_CODE}})
# SINH TU DONG boi prodiab-clinic-gen — KHONG sua tay (sua template deploy/template/).
# Moi phong kham = 1 stack + 1 DB rieng, coexist nhieu stack tren cung VM.
# Deploy:  cd deploy/deployments/{{CLINIC_CODE}} && docker compose up -d --build
# Secrets lay tu .env cung thu muc (docker compose tu doc).
# =====================================================================
name: prodiab-{{CLINIC_CODE}}

services:
  mysql:
    image: mysql:8.0.36
    container_name: prodiab-{{CLINIC_CODE}}-mysql
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: ${DB_ROOT_PASSWORD}
      MYSQL_DATABASE: ${DB_NAME}
      MYSQL_USER: ${DB_USER}
      MYSQL_PASSWORD: ${DB_PASSWORD}
    volumes:
      - mysql-data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "root", "-p${DB_ROOT_PASSWORD}"]
      interval: 15s
      timeout: 10s
      retries: 8
      start_period: 45s
    networks: [prodiab-{{CLINIC_CODE}}-net]

  # One-shot: chay migration 9xxx (tru demo) + seed.sql roi thoat. Backend cho service nay xong.
  migrator:
    image: mysql:8.0.36
    container_name: prodiab-{{CLINIC_CODE}}-migrator
    restart: on-failure
    depends_on:
      mysql:
        condition: service_healthy
    environment:
      DB_NAME: ${DB_NAME}
      DB_ROOT_PASSWORD: ${DB_ROOT_PASSWORD}
    volumes:
      - {{REPO_REL}}/db:/db:ro
      - ./seed.sql:/seed.sql:ro
      - ./migrate.sh:/migrate.sh:ro
    entrypoint: ["bash", "/migrate.sh"]
    networks: [prodiab-{{CLINIC_CODE}}-net]

  redis:
    image: redis:7.4-alpine
    container_name: prodiab-{{CLINIC_CODE}}-redis
    restart: unless-stopped
    command: redis-server --requirepass ${REDIS_PASSWORD} --appendonly yes
    volumes:
      - redis-data:/data
    networks: [prodiab-{{CLINIC_CODE}}-net]

  minio:
    image: minio/minio:latest
    container_name: prodiab-{{CLINIC_CODE}}-minio
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
    volumes:
      - minio-data:/data
    networks: [prodiab-{{CLINIC_CODE}}-net]

  backend:
    build:
      context: {{REPO_REL}}/backend
      dockerfile: Dockerfile
    image: prodiab-{{CLINIC_CODE}}-backend:latest
    container_name: prodiab-{{CLINIC_CODE}}-backend
    restart: unless-stopped
    environment:
      ASPNETCORE_ENVIRONMENT: Production
      ASPNETCORE_URLS: "http://+:5000"
      ConnectionStrings__DefaultConnection: "Server=mysql;Port=3306;Database=${DB_NAME};User=${DB_USER};Password=${DB_PASSWORD};CharSet=utf8mb4;GuidFormat=None;SslMode=None;AllowPublicKeyRetrieval=true;"
      ConnectionStrings__Redis: "redis:6379,password=${REDIS_PASSWORD},ssl=False,abortConnect=False"
      Minio__Endpoint: "minio:9000"
      Minio__AccessKey: ${MINIO_ROOT_USER}
      Minio__SecretKey: ${MINIO_ROOT_PASSWORD}
      Minio__UseSSL: "false"
      Jwt__Secret: ${JWT_SECRET}
      Jwt__Issuer: ${JWT_ISSUER}
      Jwt__Audience: ${JWT_AUDIENCE}
      Jwt__AccessTokenExpiryMinutes: "60"
      Jwt__RefreshTokenExpiryDays: "7"
      Encryption__MasterKey: ${ENCRYPTION_MASTER_KEY}
      CorsHardening__AllowedOrigins__0: ${APP_PUBLIC_URL}
      Platform__BaseDomain: {{BASE_DOMAIN}}
      Smtp__Host: ${SMTP_HOST}
      Smtp__Port: ${SMTP_PORT}
      Smtp__Username: ${SMTP_USER}
      Smtp__Password: ${SMTP_PASS}
      Smtp__FromEmail: ${SMTP_FROM}
      Smtp__UseSsl: ${SMTP_SSL}
    depends_on:
      mysql:
        condition: service_healthy
      migrator:
        condition: service_completed_successfully
      redis:
        condition: service_started
      minio:
        condition: service_started
    healthcheck:
      test: ["CMD-SHELL", "curl -s -o /dev/null http://localhost:5000/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    networks: [prodiab-{{CLINIC_CODE}}-net]

  frontend:
    build:
      context: {{REPO_REL}}/frontend
      dockerfile: Dockerfile
      args:
        NEXT_PUBLIC_API_BASE_URL: ${APP_PUBLIC_URL}
    image: prodiab-{{CLINIC_CODE}}-frontend:latest
    container_name: prodiab-{{CLINIC_CODE}}-frontend
    restart: unless-stopped
    environment:
      NODE_ENV: production
      NEXT_TELEMETRY_DISABLED: "1"
    depends_on:
      backend:
        condition: service_started
    healthcheck:
      test: ["CMD-SHELL", "curl -s -o /dev/null http://localhost:3000/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 45s
    networks: [prodiab-{{CLINIC_CODE}}-net]

  nginx:
    image: nginx:1.27-alpine
    container_name: prodiab-{{CLINIC_CODE}}-nginx
    restart: unless-stopped
    ports:
      - "172.17.0.1:{{NGINX_PORT}}:80"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      frontend:
        condition: service_started
      backend:
        condition: service_started
    networks: [prodiab-{{CLINIC_CODE}}-net]

networks:
  prodiab-{{CLINIC_CODE}}-net:
    driver: bridge
    name: prodiab-{{CLINIC_CODE}}-net

volumes:
  mysql-data:
  redis-data:
  minio-data:
