# =====================================================================
# .env — phong kham {{CLINIC_NAME}} ({{CLINIC_CODE}})
# SINH TU DONG boi prodiab-clinic-gen. CHUA SECRET — KHONG commit vao git.
# =====================================================================

# --- MySQL (secret tu sinh) ---
DB_ROOT_PASSWORD={{DB_ROOT_PASSWORD}}
DB_NAME={{DB_NAME}}
DB_USER={{DB_USER}}
DB_PASSWORD={{DB_PASSWORD}}

# --- Redis (secret tu sinh) ---
REDIS_PASSWORD={{REDIS_PASSWORD}}

# --- MinIO (secret tu sinh) ---
MINIO_ROOT_USER={{MINIO_ROOT_USER}}
MINIO_ROOT_PASSWORD={{MINIO_ROOT_PASSWORD}}

# --- JWT (secret tu sinh) ---
JWT_SECRET={{JWT_SECRET}}
JWT_ISSUER=ProDiabHis
JWT_AUDIENCE=ProDiabHis.Clients

# --- Ma hoa cot nhay cam AES-256-GCM (base64 32 bytes, tu sinh, BAT BUOC) ---
ENCRYPTION_MASTER_KEY={{ENCRYPTION_MASTER_KEY}}

# --- App / domain ---
APP_ENV=production
APP_PUBLIC_URL=https://{{DOMAIN}}

# --- SMTP (khach nhap; de trong neu chua co) ---
SMTP_HOST={{SMTP_HOST}}
SMTP_PORT={{SMTP_PORT}}
SMTP_USER={{SMTP_USER}}
SMTP_PASS={{SMTP_PASS}}
SMTP_FROM={{SMTP_FROM}}
SMTP_SSL={{SMTP_SSL}}

# --- Sentry (tuy chon) ---
SENTRY_DSN={{SENTRY_DSN}}
